{
  "crons": [
    {
      "path": "/api/markets-expire-orders",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/lending-index-cron",
      "schedule": "*/5 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:route*",
      "destination": "/api?route=:route*"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}
